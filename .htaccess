# Enable URL rewriting for SPA
RewriteEngine On

# Redirect all requests to index.html except actual files/directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# Cache static assets for 1 month
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico|woff2|woff|ttf|eot)$">
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
</FilesMatch>

# Disable directory listing
Options -Indexes